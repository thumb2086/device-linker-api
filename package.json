{
  "name": "device-linker-monolith",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "postbuild": "shx cp apps/web/dist/index.html ./index.html && shx cp -r apps/web/dist/assets ./assets || shx true",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "shx": "^0.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
